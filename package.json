{
  "name": "egepalas-oys",
  "version": "1.0.0",
  "description": "Ege Palas Hotel Management System",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac"
  },
  "author": {
    "name": "Ege Palas Hotel",
    "email": "info@egepalashotel.com"
  },
  "license": "MIT",
  "dependencies": {
    "@electron/rebuild": "^4.0.2",
    "@electron/remote": "^2.1.0",
    "better-sqlite3": "^12.5.0",
    "flatpickr": "^4.6.13"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.egepalas.oys",
    "productName": "Ege Palas OYS",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!dist/**"
    ],
    "afterPack": "build/afterPack.js",
    "mac": {
      "category": "public.app-category.business",
      "target": [
        {
          "target": "pkg",
          "arch": ["x64", "arm64"]
        }
      ],
      "icon": "build/icon.png",
      "identity": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "pkg": {
      "scripts": "build/pkg-scripts",
      "installLocation": "/Applications",
      "isRelocatable": false,
      "isVersionChecked": false,
      "hasStrictIdentifier": false,
      "overwriteAction": "upgrade"
    },
    "asar": true,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "build/icon_win.ico",
      "publisherName": "Ege Palas Hotel",
      "legalTrademarks": "Ege Palas Hotel Management System"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon_win.ico",
      "uninstallerIcon": "build/icon_win.ico",
      "installerHeaderIcon": "build/icon_win.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Ege Palas OYS",
      "artifactName": "EgePalasOYS-Setup-${version}.${ext}",
      "deleteAppDataOnUninstall": false
    }
  }
}
